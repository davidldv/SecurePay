# Copy to .env and fill. Never commit .env.
PG_AUTH_PW=change-me-auth
PG_ACCT_PW=change-me-acct
PG_TX_PW=change-me-tx
REDIS_PW=change-me-redis

# Shared secret for internal service-to-service calls (transaction -> account).
# Generate: openssl rand -hex 32
SERVICE_TOKEN=

# RSA keys (PEM base64 body, one line each). Generate via scripts/gen-keys.sh.
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
